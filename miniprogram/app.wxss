page {
  min-height: 100vh;
  background: #f4f6f0;
  color: #101827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 52rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  margin: 0 -2rpx 28rpx;
  padding: 28rpx 28rpx 30rpx;
  border: 1rpx solid rgba(219, 234, 254, 0.72);
  border-radius: 16rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f7fbff 54%, #e9f4ee 100%);
  box-shadow: 0 18rpx 44rpx rgba(30, 64, 175, 0.07);
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 10rpx;
  height: 100%;
  background: linear-gradient(180deg, #245f59 0%, #58a992 54%, #f2bd52 100%);
}

.eyebrow {
  position: relative;
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #dff0e8;
  color: #245f59;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  position: relative;
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: 0;
}

.subtitle {
  position: relative;
  margin-top: 14rpx;
  color: #526174;
  font-size: 26rpx;
  line-height: 1.6;
}

.panel {
  margin-bottom: 22rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #d9dfd7;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.045);
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.panel-title {
  color: #0f172a;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 900;
}

.field-name {
  display: none;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  min-height: 68rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d5ddd8;
  border-radius: 999rpx;
  background: #fbfcfa;
  color: #25324a;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 68rpx;
  box-sizing: border-box;
  transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
}

.chip-active {
  border-color: #245f59;
  background: linear-gradient(135deg, #245f59 0%, #2f7f72 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(30, 64, 175, 0.18);
}

.textarea {
  width: 100%;
  min-height: 164rpx;
  padding: 22rpx;
  border: 1rpx solid #d5ddd8;
  border-radius: 16rpx;
  background: #f7faf5;
  color: #101827;
  font-size: 27rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.hint {
  margin-top: 14rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.55;
}

.primary-button {
  width: 100%;
  height: 92rpx;
  margin-top: 10rpx;
  border: 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #245f59 0%, #2f7f72 58%, #d69b35 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 92rpx;
  box-shadow: 0 16rpx 32rpx rgba(30, 64, 175, 0.22);
}

.secondary-button {
  width: 100%;
  height: 84rpx;
  margin-top: 14rpx;
  border: 1rpx solid #d5ddd8;
  border-radius: 16rpx;
  background: #ffffff;
  color: #174b46;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 84rpx;
}

button::after {
  border: 0;
}

button[disabled],
.button-disabled {
  opacity: 0.52;
}

.summary-list {
  display: grid;
  gap: 12rpx;
}

.summary-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f7faff;
}

.summary-label {
  flex: 0 0 150rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 800;
}

.summary-value {
  flex: 1;
  color: #1e293b;
  font-size: 24rpx;
  line-height: 1.45;
}
