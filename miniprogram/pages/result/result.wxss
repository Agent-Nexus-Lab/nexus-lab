.request-card {
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
  color: #26344a;
  font-size: 26rpx;
  line-height: 1.55;
}

.event-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #dde5f0;
  border-radius: 18rpx;
  background: #fbfcff;
}

.event-topline {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.event-order,
.event-score {
  color: #68758a;
  font-size: 22rpx;
  font-weight: 750;
}

.event-title {
  color: #172033;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.4;
}

.event-summary {
  margin-top: 10rpx;
  color: #5f6d82;
  font-size: 25rpx;
  line-height: 1.55;
}

.event-meta {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  color: #344258;
  font-size: 24rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.small-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #3158b4;
  font-size: 21rpx;
  font-weight: 700;
}

.reason-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f0f5ff;
  color: #294576;
  font-size: 24rpx;
  line-height: 1.55;
}

.source-text {
  margin-top: 14rpx;
  color: #7c8797;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}
