.request-card {
  padding: 22rpx 24rpx;
  border: 1rpx solid #e3ebf6;
  border-radius: 16rpx;
  background: #f8fbff;
  color: #1e293b;
  font-size: 26rpx;
  line-height: 1.55;
}

.history-button {
  width: 100%;
  height: 76rpx;
  margin: 0 0 20rpx;
  border: 1rpx solid #c9d9f2;
  border-radius: 16rpx;
  background: #f8fbff;
  color: #1e40af;
  font-size: 26rpx;
  font-weight: 900;
}

.event-card {
  position: relative;
  margin-top: 20rpx;
  padding: 28rpx 26rpx;
  border: 1rpx solid #dbe6f6;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.045);
  overflow: hidden;
}

.event-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 8rpx;
  border-radius: 0 999rpx 999rpx 0;
  background: linear-gradient(180deg, #2563eb 0%, #14b8a6 100%);
}

.empty-state {
  margin-top: 18rpx;
  padding: 34rpx 26rpx;
  border: 1rpx dashed #bfd0e7;
  border-radius: 16rpx;
  background: #f8fbff;
  text-align: center;
}

.empty-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 10rpx;
  color: #68758a;
  font-size: 24rpx;
  line-height: 1.55;
}

.event-topline {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.event-order,
.event-score {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 850;
}

.event-score {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #1e40af;
}

.event-title {
  position: relative;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.event-summary {
  margin-top: 12rpx;
  color: #526174;
  font-size: 25rpx;
  line-height: 1.55;
}

.event-meta {
  display: grid;
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  background: #f6f9fd;
  color: #25324a;
  font-size: 24rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.small-tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #1e40af;
  font-size: 21rpx;
  font-weight: 800;
}

.reason-box {
  margin-top: 18rpx;
  padding: 20rpx;
  border-left: 6rpx solid #3b82f6;
  border-radius: 16rpx;
  background: #eef6ff;
  color: #1e3a6d;
  font-size: 24rpx;
  line-height: 1.55;
}

.source-text {
  margin-top: 14rpx;
  color: #7c8797;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.source-link {
  color: #1e40af;
  font-weight: 900;
}

.feedback-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.feedback-button {
  min-width: 144rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #d8e3f0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #25324a;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 64rpx;
}

.feedback-button.active {
  border-color: #1e40af;
  background: #e9f2ff;
  color: #1e40af;
}

.feedback-button.danger.active {
  border-color: #dc8a78;
  background: #fff4ee;
  color: #a94734;
}

.feedback-button.source {
  border-color: #bcd0ee;
  color: #1e40af;
}

.debug-panel {
  border-color: #dce6f4;
  background: #f8fbff;
}

.debug-text {
  display: block;
  margin-top: 14rpx;
  color: #68758a;
  font-family: monospace;
  font-size: 20rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
}
