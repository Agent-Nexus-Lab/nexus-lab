<view class="page">
  <view class="hero">
    <view class="eyebrow">生成结果</view>
    <view class="title">{{result.title}}</view>
    <view class="subtitle">{{result.summary}}</view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view class="panel-title">本次输入</view>
      <view class="field-name">{{result.date_scope}}</view>
    </view>
    <view class="request-card">{{result.request_text}}</view>
  </view>

  <button class="history-button" bindtap="goHistory">查看历史规划</button>

  <view wx:if="{{composer.hasContent}}" class="panel composer-panel">
    <view class="panel-head">
      <view class="panel-title">推荐说明</view>
      <view class="field-name">Agent 总结</view>
    </view>
    <view wx:if="{{composer.summary}}" class="composer-main">{{composer.summary}}</view>
    <view wx:if="{{composer.recommendedItemsText}}" class="composer-row">
      <view class="composer-label">推荐重点</view>
      <view class="composer-value">{{composer.recommendedItemsText}}</view>
    </view>
    <view wx:if="{{composer.tradeoffsText}}" class="composer-row">
      <view class="composer-label">取舍说明</view>
      <view class="composer-value">{{composer.tradeoffsText}}</view>
    </view>
    <view wx:if="{{composer.followUpQuestion}}" class="composer-follow">{{composer.followUpQuestion}}</view>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view class="panel-title">活动卡片</view>
      <view class="field-name">{{result.items.length}} 个结果</view>
    </view>

    <view wx:if="{{!hasItems}}" class="empty-state">
      <view class="empty-title">暂无可展示活动</view>
      <view class="empty-text">后端已返回结果，但本次没有活动卡片。可以调整时间范围或偏好后重新生成。</view>
    </view>

    <view
      wx:else
      wx:for="{{result.items}}"
      wx:key="feedback_key"
      class="event-card"
    >
      <view class="event-topline">
        <view class="event-order">#{{item.display_order}}</view>
        <view class="event-score">质量分 {{item.quality_score}}</view>
      </view>
      <view class="event-title">{{item.title}}</view>
      <view class="event-summary">{{item.summary}}</view>

      <view class="event-meta">
        <view class="event-meta-row">
          <view class="meta-icon meta-time"></view>
          <view>时间：{{item.time_text}}</view>
        </view>
        <view class="event-meta-row">
          <view class="meta-icon meta-location"></view>
          <view>地点：{{item.location}}</view>
        </view>
        <view class="event-meta-row">
          <view class="meta-icon meta-campus"></view>
          <view>校区：{{item.campus}}</view>
        </view>
        <view class="event-meta-row">
          <view class="meta-icon meta-organizer"></view>
          <view>主办：{{item.organizer}}</view>
        </view>
      </view>

      <view class="tag-row">
        <view
          wx:for="{{item.tags}}"
          wx:key="*this"
          wx:for-item="tag"
          class="small-tag"
        >{{tag}}</view>
      </view>

      <view class="reason-box">{{item.reason_text}}</view>

      <view wx:if="{{item.has_score_reasons}}" class="score-reason-grid">
        <view
          wx:for="{{item.score_reasons}}"
          wx:key="id"
          wx:for-item="reason"
          class="score-reason-chip"
        >
          <text class="score-reason-label">{{reason.label}}</text>
          <text class="score-reason-value">{{reason.value}}</text>
        </view>
      </view>

      <view class="source-row">
        <view class="source-label">来源</view>
        <button
          wx:if="{{item.has_source_url}}"
          class="source-inline-link"
          data-index="{{index}}"
          bindtap="openSource"
        >{{item.source_text}}</button>
        <view wx:else class="source-inline-text">{{item.source_text}}</view>
      </view>

      <view class="feedback-row">
        <button
          class="feedback-button {{item.feedback_type === 'like' ? 'active' : ''}}"
          loading="{{item.feedback_pending && item.feedback_type === 'like'}}"
          data-index="{{index}}"
          data-type="like"
          bindtap="submitFeedback"
        >
          <view class="feedback-icon icon-like"></view>
          <text>{{item.feedback_type === 'like' ? '已喜欢' : '喜欢'}}</text>
        </button>
        <button
          class="feedback-button {{item.feedback_type === 'dislike' ? 'danger active' : ''}}"
          loading="{{item.feedback_pending && item.feedback_type === 'dislike'}}"
          data-index="{{index}}"
          data-type="dislike"
          bindtap="submitFeedback"
        >
          <view class="feedback-icon icon-dislike"></view>
          <text>{{item.feedback_type === 'dislike' ? '已减少推荐' : '不感兴趣'}}</text>
        </button>
        <button
          wx:if="{{item.has_source_url}}"
          class="feedback-button source"
          data-index="{{index}}"
          bindtap="openSource"
        >
          <view class="feedback-icon icon-source"></view>
          <text>{{item.source_clicked ? '已查看来源' : '查看来源'}}</text>
        </button>
      </view>

    </view>
  </view>

  <view wx:if="{{debugText}}" class="panel debug-panel">
    <view class="panel-title">开发调试信息</view>
    <text selectable class="debug-text">{{debugText}}</text>
  </view>

  <button class="primary-button" bindtap="goPlan">重新生成</button>
</view>
