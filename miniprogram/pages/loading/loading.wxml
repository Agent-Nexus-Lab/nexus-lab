<view class="page loading-page">
  <view class="loading-card">
    <view class="runtime-visual runtime-{{viewState}}">
      <view wx:if="{{viewState === 'running'}}" class="runtime-ring">
        <view class="runtime-node runtime-node-a"></view>
        <view class="runtime-node runtime-node-b"></view>
        <view class="runtime-core"></view>
      </view>
      <view wx:elif="{{viewState === 'completed'}}" class="state-icon state-success">
        <view class="icon-check"></view>
      </view>
      <view wx:else class="state-icon state-failed">
        <view class="icon-alert"></view>
      </view>
    </view>
    <view class="status-badge status-{{viewState}}">{{statusLabel}}</view>
    <view class="loading-title">{{currentMessage}}</view>
    <view wx:if="{{viewState !== 'failed'}}" class="loading-subtitle">正在根据你的偏好、时间范围和活动库生成结果。</view>
    <view wx:else class="error-message">{{errorMessage}}</view>

    <view class="progress-track">
      <view class="progress-bar" style="width: {{progress}}%;"></view>
    </view>
    <view class="progress-caption">进度 {{progressText}}</view>

    <view class="step-list">
      <view
        wx:for="{{steps}}"
        wx:key="text"
        class="step-item {{index <= activeStep ? 'step-active' : ''}}"
      >
        <view class="step-dot">
          <view class="step-dot-mark"></view>
        </view>
        <view class="step-text">{{item.text}}</view>
      </view>
    </view>

    <view wx:if="{{viewState === 'failed'}}" class="action-row">
      <button class="secondary-button" bindtap="goPlan">返回修改</button>
      <button class="primary-button retry-button" bindtap="goPlan">重新生成</button>
    </view>

    <view wx:if="{{failureDetails.length > 0}}" class="failure-panel">
      <view class="debug-title">失败原因</view>
      <view wx:for="{{failureDetails}}" wx:key="id" class="failure-item">{{item.text}}</view>
    </view>

    <view wx:if="{{rewriteNotice}}" class="rewrite-notice">
      <view class="debug-title">文案降级</view>
      <view class="rewrite-text">{{rewriteNotice}}</view>
    </view>

    <view wx:if="{{dataHealth}}" class="data-health-panel data-health-{{dataHealth.statusClass}}">
      <view class="data-health-head">
        <view>
          <view class="debug-title">数据健康</view>
          <view class="data-health-subtitle">仅开发模式可见</view>
        </view>
        <view class="health-status">
          <view class="health-signal">
            <view class="signal-bar signal-1"></view>
            <view class="signal-bar signal-2"></view>
            <view class="signal-bar signal-3"></view>
          </view>
          <view class="health-badge">{{dataHealth.healthLabel}}</view>
        </view>
      </view>

      <view class="health-metrics">
        <view class="health-metric">
          <view class="metric-value">{{dataHealth.total_events}}</view>
          <view class="metric-label">活动总数</view>
        </view>
        <view class="health-metric">
          <view class="metric-value">{{dataHealth.future_events_7d}}</view>
          <view class="metric-label">未来 7 天</view>
        </view>
        <view class="health-metric">
          <view class="metric-value">{{dataHealth.future_events_14d}}</view>
          <view class="metric-label">未来 14 天</view>
        </view>
      </view>

      <view class="health-row">
        <view class="health-row-label">最近采集</view>
        <view class="health-row-value">{{dataHealth.lastCollectionText}} · {{dataHealth.last_collection_result}}</view>
      </view>
      <view class="health-row">
        <view class="health-row-label">来源分布</view>
        <view class="health-row-value">{{dataHealth.sourceSummary}}</view>
      </view>

      <view wx:if="{{dataHealth.alerts.length > 0}}" class="health-alerts">
        <view wx:for="{{dataHealth.alerts}}" wx:key="*this" class="health-alert">{{item}}</view>
      </view>

      <view class="collection-log-panel">
        <view class="debug-title">采集日志</view>
        <view wx:for="{{dataHealth.collectionLogs}}" wx:key="id" class="collection-log-item {{item.isEmpty ? 'collection-log-empty' : ''}}">
          <view class="collection-log-topline">
            <view class="collection-log-main">{{item.batchText}}</view>
            <view class="collection-log-status">{{item.result}}</view>
          </view>
          <view class="collection-log-sub">{{item.source}} · {{item.timeText}} · {{item.triggerText}}</view>
          <view class="collection-log-stats">{{item.statsText}}</view>
          <view wx:if="{{item.failureText}}" class="collection-log-failure">{{item.failureText}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{dataHealthError}}" class="data-health-panel data-health-warning">
      <view class="data-health-head">
        <view>
          <view class="debug-title">数据健康</view>
          <view class="data-health-subtitle">仅开发模式可见</view>
        </view>
        <view class="health-badge">未连接</view>
      </view>
      <view class="health-alert">{{dataHealthError}}</view>
    </view>

    <view wx:if="{{debugText}}" class="debug-panel">
      <view class="debug-title">开发调试信息</view>
      <text selectable class="debug-text">{{debugText}}</text>
    </view>
  </view>
</view>
