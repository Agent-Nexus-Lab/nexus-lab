.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-card {
  width: 100%;
  padding: 54rpx 34rpx 36rpx;
  border: 1rpx solid #e5eaf2;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(23, 32, 51, 0.06);
  box-sizing: border-box;
}

.spinner {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 28rpx;
  border: 8rpx solid #e6edfb;
  border-top-color: #2f65e8;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.state-icon {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 20rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 850;
}

.state-success {
  background: #2a9d68;
}

.state-failed {
  background: #d94b4b;
}

.status-badge {
  display: table;
  margin: 0 auto 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #3158b4;
  font-size: 22rpx;
  font-weight: 750;
}

.status-failed {
  background: #fff0f0;
  color: #b33838;
}

.status-completed {
  background: #edf9f2;
  color: #238454;
}

.loading-title {
  text-align: center;
  color: #172033;
  font-size: 36rpx;
  font-weight: 850;
  line-height: 1.35;
}

.loading-subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: #69778b;
  font-size: 25rpx;
  line-height: 1.55;
}

.error-message {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff5f5;
  color: #a13b3b;
  font-size: 24rpx;
  line-height: 1.55;
}

.progress-track {
  height: 14rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #eef2f8;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #2f65e8;
  transition: width 0.3s ease;
}

.step-list {
  display: grid;
  gap: 18rpx;
  margin-top: 34rpx;
}

.step-item {
  display: flex;
  gap: 14rpx;
  align-items: center;
  color: #8a96a8;
  font-size: 25rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c9d2df;
}

.step-active {
  color: #25324a;
  font-weight: 750;
}

.step-active .step-dot {
  background: #2f65e8;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 30rpx;
}

.secondary-button,
.retry-button {
  margin: 0;
}

.secondary-button {
  border: 1rpx solid #d6deea;
  background: #ffffff;
  color: #344258;
}

.debug-panel {
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
}

.data-health-panel {
  margin-top: 28rpx;
  padding: 22rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 18rpx;
  background: #f8fbff;
}

.data-health-warning {
  border-color: #f3d29b;
  background: #fff8ea;
}

.data-health-healthy {
  border-color: #cfe8d9;
  background: #f3fbf6;
}

.data-health-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.data-health-subtitle {
  margin-top: 4rpx;
  color: #7a8798;
  font-size: 20rpx;
}

.health-badge {
  min-width: 92rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #1e40af;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.data-health-warning .health-badge {
  color: #a05a00;
}

.data-health-healthy .health-badge {
  color: #237a50;
}

.health-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.health-metric {
  min-height: 104rpx;
  padding: 14rpx 10rpx;
  border: 1rpx solid rgba(30, 64, 175, 0.08);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.metric-value {
  color: #172033;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.2;
}

.metric-label {
  margin-top: 6rpx;
  color: #68758a;
  font-size: 20rpx;
  line-height: 1.25;
}

.health-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #344258;
  font-size: 23rpx;
  line-height: 1.45;
}

.health-row-label {
  flex: 0 0 108rpx;
  color: #6a778b;
  font-weight: 700;
}

.health-row-value {
  flex: 1;
  word-break: break-all;
}

.health-alerts {
  display: grid;
  gap: 10rpx;
  margin-top: 18rpx;
}

.health-alert {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(217, 119, 6, 0.12);
  color: #8a4f00;
  font-size: 22rpx;
  line-height: 1.45;
}

.debug-title {
  margin-bottom: 10rpx;
  color: #5f6d82;
  font-size: 22rpx;
  font-weight: 750;
}

.debug-text {
  color: #68758a;
  font-family: monospace;
  font-size: 20rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
