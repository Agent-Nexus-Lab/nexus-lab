.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 18% 8%, rgba(59, 130, 246, 0.08), transparent 34%),
    radial-gradient(circle at 88% 22%, rgba(20, 184, 166, 0.08), transparent 30%),
    #f4f7fb;
}

.loading-card {
  width: 100%;
  padding: 54rpx 34rpx 38rpx;
  border: 1rpx solid #dce6f4;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 22rpx 58rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.spinner {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 28rpx;
  border: 8rpx solid #e6eef9;
  border-top-color: #1e40af;
  border-right-color: #14b8a6;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.state-icon {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 20rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 850;
}

.state-success {
  background: #16a36d;
}

.state-failed {
  background: #dc2626;
}

.status-badge {
  display: table;
  margin: 0 auto 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e9f2ff;
  color: #1e40af;
  font-size: 22rpx;
  font-weight: 750;
}

.status-failed {
  background: #fff0f0;
  color: #b91c1c;
}

.status-completed {
  background: #ecfdf3;
  color: #15803d;
}

.loading-title {
  text-align: center;
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
}

.loading-subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.55;
}

.error-message {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff5f5;
  color: #991b1b;
  font-size: 24rpx;
  line-height: 1.55;
}

.progress-track {
  height: 14rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #e7edf6;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1e40af 0%, #2563eb 58%, #14b8a6 100%);
  transition: width 0.3s ease;
}

.step-list {
  display: grid;
  gap: 16rpx;
  margin-top: 34rpx;
}

.step-item {
  display: flex;
  gap: 14rpx;
  align-items: center;
  padding: 14rpx 16rpx;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  color: #7a8798;
  font-size: 25rpx;
  transition: background 0.2s ease, border-color 0.2s ease;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c9d2df;
}

.step-active {
  border-color: #dbeafe;
  background: #f5f9ff;
  color: #1e293b;
  font-weight: 850;
}

.step-active .step-dot {
  background: #2563eb;
  box-shadow: 0 0 0 8rpx rgba(37, 99, 235, 0.1);
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 30rpx;
}

.secondary-button,
.retry-button {
  margin: 0;
}

.secondary-button {
  border: 1rpx solid #d6e2f0;
  background: #ffffff;
  color: #1e3a8a;
}

.debug-panel {
  margin-top: 28rpx;
  padding: 18rpx;
  border: 1rpx solid #dce6f4;
  border-radius: 16rpx;
  background: #f8fbff;
}

.data-health-panel {
  margin-top: 28rpx;
  padding: 22rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 16rpx;
  background: #f8fbff;
}

.data-health-warning {
  border-color: #f3d29b;
  background: #fff8ea;
}

.data-health-healthy {
  border-color: #cfe8d9;
  background: #f3fbf6;
}

.data-health-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.data-health-subtitle {
  margin-top: 4rpx;
  color: #7a8798;
  font-size: 20rpx;
}

.health-badge {
  min-width: 92rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #1e40af;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.data-health-warning .health-badge {
  color: #a05a00;
}

.data-health-healthy .health-badge {
  color: #237a50;
}

.health-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.health-metric {
  min-height: 104rpx;
  padding: 14rpx 10rpx;
  border: 1rpx solid rgba(30, 64, 175, 0.1);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.metric-value {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 850;
  line-height: 1.2;
}

.metric-label {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 20rpx;
  line-height: 1.25;
}

.health-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #25324a;
  font-size: 23rpx;
  line-height: 1.45;
}

.health-row-label {
  flex: 0 0 108rpx;
  color: #6a778b;
  font-weight: 700;
}

.health-row-value {
  flex: 1;
  word-break: break-all;
}

.health-alerts {
  display: grid;
  gap: 10rpx;
  margin-top: 18rpx;
}

.health-alert {
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(217, 119, 6, 0.12);
  color: #8a4f00;
  font-size: 22rpx;
  line-height: 1.45;
}

.debug-title {
  margin-bottom: 10rpx;
  color: #526174;
  font-size: 22rpx;
  font-weight: 850;
}

.debug-text {
  color: #64748b;
  font-family: monospace;
  font-size: 20rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
