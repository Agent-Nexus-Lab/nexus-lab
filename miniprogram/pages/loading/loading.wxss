.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-card {
  width: 100%;
  padding: 54rpx 34rpx 36rpx;
  border: 1rpx solid #e5eaf2;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(23, 32, 51, 0.06);
  box-sizing: border-box;
}

.spinner {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 28rpx;
  border: 8rpx solid #e6edfb;
  border-top-color: #2f65e8;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-title {
  text-align: center;
  color: #172033;
  font-size: 36rpx;
  font-weight: 850;
  line-height: 1.35;
}

.loading-subtitle {
  margin-top: 12rpx;
  text-align: center;
  color: #69778b;
  font-size: 25rpx;
  line-height: 1.55;
}

.progress-track {
  height: 14rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #eef2f8;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #2f65e8;
  transition: width 0.3s ease;
}

.step-list {
  display: grid;
  gap: 18rpx;
  margin-top: 34rpx;
}

.step-item {
  display: flex;
  gap: 14rpx;
  align-items: center;
  color: #8a96a8;
  font-size: 25rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c9d2df;
}

.step-active {
  color: #25324a;
  font-weight: 750;
}

.step-active .step-dot {
  background: #2f65e8;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
