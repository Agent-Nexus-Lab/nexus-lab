.history-list {
  display: grid;
  gap: 20rpx;
}

.history-card,
.empty-state {
  padding: 26rpx 24rpx;
  border: 1rpx solid #d9dfd7;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.045);
}

.history-topline {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
}

.history-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.history-status {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #dff0e8;
  color: #245f59;
  font-size: 20rpx;
  font-weight: 850;
}

.history-summary,
.empty-text {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.55;
}

.history-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #64748b;
  font-size: 22rpx;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-button {
  width: 100%;
  height: 78rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #245f59 0%, #2f7f72 58%, #d69b35 100%);
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
}
